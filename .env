# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Firebase — values from firebase-applet-config.json / Firebase Console.
# These are NOT secret in the traditional sense (they identify your project,
# they don't authorize access — Firestore security rules are what actually
# gate access). Still moved to env vars so they're not duplicated across
# committed files and can differ between dev/staging/prod projects.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY="AIzaSyANn7DJq76nrxMRY25vO8sAcEiRIE8Rd8c"
VITE_FIREBASE_AUTH_DOMAIN="gen-lang-client-0420782130.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="gen-lang-client-0420782130"
VITE_FIREBASE_STORAGE_BUCKET="gen-lang-client-0420782130.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="507824012838"
VITE_FIREBASE_APP_ID="1:507824012838:web:c2107667b88fe8032c70e7"
VITE_FIREBASE_FIRESTORE_DB_ID="ai-studio-a5c4dd4a-323c-4393-886f-818343a351d5"

# ---------------------------------------------------------------------------
# Cloudinary — used for JSON archival of closed attendance sessions.
# upload_preset must remain "unsigned" mode for this client-side flow to
# work; that means anyone with this preset name can upload to your account.
# Treat it as semi-sensitive: rotate it if abused, don't advertise it.
# ---------------------------------------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME="dilrcexxe"
VITE_CLOUDINARY_UPLOAD_PRESET="MingleKe"
VITE_CLOUDINARY_FOLDER_PREFIX="ksas/"
